# Copy this file to .streamlit/secrets.toml and fill in your real values.
# NEVER commit secrets.toml to version control.

[woocommerce]
store_url = "https://your-store.com"
consumer_key = "ck_your_consumer_key_here"
consumer_secret = "cs_your_consumer_secret_here"

[pathao]
base_url = "https://api-hermes.pathao.com"
client_id = "your_client_id"
client_secret = "your_client_secret"
username = "your_email@example.com"
password = "your_password"

[llm]
# Add your API keys below. You only need to provide the ones you want to use.
openrouter_key = "sk-or-v1-your_openrouter_key_here"
gemini_key = "your_gemini_api_key_here"
groq_key = "gsk_your_groq_key_here"
huggingface_key = "hf_your_huggingface_key_here"
